# Producción (Vercel) — Project Settings → Environment Variables

# --- Servidor (secretos — NO marcar "Expose to browser") ---
BACKEND_URL=https://your-backend.onrender.com
SAAS_API_KEY=your-saas-api-key

# --- Cliente (públicas) ---
NEXT_PUBLIC_WS_URL=https://your-backend.onrender.com
NEXT_PUBLIC_CLINIC_SLUG=consultorio-ensigna
NEXT_PUBLIC_APP_URL=https://ensigna-mocha.vercel.app

# En Render (backend), configurar CORS_ORIGINS con el dominio de Vercel:
# CORS_ORIGINS=https://ensigna-mocha.vercel.app,https://ensigna.com,https://www.ensigna.com
