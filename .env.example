# Desarrollo local — copiar a .env.local
# Secretos SOLO del servidor (nunca NEXT_PUBLIC_*)
BACKEND_URL=http://localhost:3333
SAAS_API_KEY=your-saas-api-key

# WebSocket: host público de Render (no es secreto, solo URL)
NEXT_PUBLIC_WS_URL=http://localhost:3333

# Públicas (seguras en el navegador)
NEXT_PUBLIC_CLINIC_SLUG=consultorio-renacer
NEXT_PUBLIC_APP_URL=http://localhost:3000
